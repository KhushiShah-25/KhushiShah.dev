# ─── Server ─────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── PostgreSQL ──────────────────────────────
# Local:      postgresql://postgres:password@localhost:5432/khushi_portfolio
# Railway:    provided automatically in dashboard
DATABASE_URL=postgresql://postgres:password@localhost:5432/khushi_portfolio

# ─── CORS ────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Email (optional — leave blank to disable) ────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password
CONTACT_EMAIL=your-gmail@gmail.com
